# Copy to .env and fill in real values. .env is gitignored — never commit it.

# --- Neon Postgres ---------------------------------------------------------
# Full connection string from the Neon console (use the POOLED or DIRECT URL).
# Must include sslmode=require.
# e.g. postgresql://user:pass@ep-xxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require
NEON_DATABASE_URL=

# --- Preset / Superset -----------------------------------------------------
# Workspace URL — the full https://...preset.io address you log into.
PRESET_WORKSPACE_URL=

# API token + secret: Preset console -> Settings -> API Keys -> Generate.
PRESET_API_TOKEN=
PRESET_API_SECRET=
